# PostgreSQL connection string (get free one from neon.tech or supabase.com)
DATABASE_URL=postgresql://user:password@host:5432/devpulse

# Redis connection string (get free one from upstash.com)
REDIS_URL=rediss://default:password@host:6379

# JWT secret — use any long random string
JWT_SECRET=replace_this_with_a_long_random_secret_string

# Server port
PORT=4000

# Environment
NODE_ENV=development
